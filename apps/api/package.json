{
  "name": "@battlecraps/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:migrate:test": "tsx --env-file=.env.test src/db/migrateTest.ts",
    "db:studio": "drizzle-kit studio",
    "db:push-unsafe": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "pino-pretty": "pino-pretty",
    "test:integration": "vitest run --config vitest.config.ts src/__tests__/integration"
  },
  "dependencies": {
    "@battlecraps/shared": "*",
    "@clerk/backend": "^3.0.0",
    "fastify": "^4.28.1",
    "@fastify/cors": "^9.0.1",
    "socket.io": "^4.7.5",
    "drizzle-orm": "^0.30.10",
    "postgres": "^3.4.4",
    "zod": "^3.23.8",
    "pino-pretty": "^11.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.21.4",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  }
}
