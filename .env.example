# =============================================================================
# BATTLECRAPS — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# The .env file is gitignored. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (used by docker-compose.yml and apps/api)
# -----------------------------------------------------------------------------

# Docker Compose will create a database using these credentials.
# The DATABASE_URL below must match them exactly.
POSTGRES_USER=battlecraps
POSTGRES_PASSWORD=battlecraps_dev
POSTGRES_DB=battlecraps
POSTGRES_PORT=5432

# Drizzle ORM connection string — consumed by apps/api at runtime.
# Format: postgres://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgres://battlecraps:battlecraps_dev@localhost:5432/battlecraps

# -----------------------------------------------------------------------------
# API server (apps/api)
# -----------------------------------------------------------------------------

# Port the Fastify server listens on.
PORT=3001

# Allowed CORS origin for the frontend dev server.
# Must match VITE_API_URL in the web section below.
CLIENT_ORIGIN=http://localhost:5173

# Node environment. Set to 'production' to disable /dev/bootstrap endpoint.
NODE_ENV=development

# -----------------------------------------------------------------------------
# Web app (apps/web)
# -----------------------------------------------------------------------------

# Base URL of the API server. Vite proxies /api/* to this in dev mode,
# but Socket.IO connects directly (no proxy), so this URL must be reachable
# from the browser.
VITE_API_URL=http://localhost:3001

# Optional: pin the dev user/run IDs for a fully deterministic dev session.
# Leave blank to use the auto-bootstrap flow (recommended).
VITE_DEV_RUN_ID=
VITE_DEV_USER_ID=
